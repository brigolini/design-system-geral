{
  "name": "@almg/al-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./styles": "./dist/styles/al-ui.css",
    "./styles/base": "./dist/styles/base.css",
    "./styles/colors": "./dist/styles/tokens/colors.css",
    "./styles/spacing": "./dist/styles/tokens/spacing.css",
    "./styles/positioning": "./dist/styles/utilities/positioning.css",
    "./styles/components/*": "./dist/styles/components/*.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build:js": "vite build",
    "build:css": "npx @tailwindcss/cli -i ./styles/al-ui.css -o ./dist/styles/al-ui.css --minify",
    "build:css:components": "node ./scripts/build-component-css.mjs",
    "build": "npm run build:js && npm run build:css && npm run build:css:components",
    "build-storybook": "storybook build",
    "deploy-storybook": "npm run build-storybook && npx gh-pages -d storybook-static",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "playground": "vite serve playground"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "downshift": "^9.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^24.1.3",
    "storybook": "^10.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  }
}
